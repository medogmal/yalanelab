# ==============================
# يالا نلعب — Environment Variables
# ==============================
# انسخ هذا الملف إلى .env وعدّل القيم

# قاعدة البيانات (Prisma — اختياري في dev)
DATABASE_URL="file:./prisma/dev.db"

# سكريت عشوائي للجلسات (مهم في production!)
# يمكن توليده بـ: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production-use-random-string"
NEXTAUTH_URL="http://localhost:3000"

# بيئة التشغيل
NODE_ENV="development"

# ==============================
# Production فقط
# ==============================

# PostgreSQL (استبدل SQLite في الإنتاج)
# DATABASE_URL="postgresql://user:password@host:5432/yalanelab"

# Email (للإشعارات — اختياري)
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""

# Redis (للـ Socket.IO multi-instance — اختياري)
# REDIS_URL="redis://localhost:6379"
