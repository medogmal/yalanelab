# ════════════════════════════════════════════════
#  YALANELAB — Production Environment Template
#  انسخ هذا الملف لـ .env.production.local وعبئ القيم
# ════════════════════════════════════════════════

# ── App ──────────────────────────────────────────
NEXTAUTH_URL=https://yalanelab.com
NEXTAUTH_SECRET=CHANGE_ME_USE_openssl_rand_base64_32

# ── Database (اختياري - لو هتستخدم Postgres) ──
DATABASE_URL=postgresql://user:pass@host:5432/yalanelab

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# أو Upstash:
# REDIS_URL=rediss://user:pass@host.upstash.io:6380

# ── SMTP (الإيميلات) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=noreply@yalanelab.com

# ── Storage (رفع الصور) ──────────────────────────
# Cloudinary (مستحسن)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# أو AWS S3
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_S3_BUCKET=yalanelab-assets

# ── Analytics (اختياري) ──────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxx

# ── Feature Flags ────────────────────────────────
NEXT_PUBLIC_ENABLE_TOURNAMENTS=true
NEXT_PUBLIC_ENABLE_FRIENDS=true
NEXT_PUBLIC_ENABLE_LIVE_STREAM=true
NEXT_PUBLIC_MAINTENANCE_MODE=false

# ── Security ─────────────────────────────────────
# Rate limit (requests per minute per IP)
RATE_LIMIT_RPM=60
